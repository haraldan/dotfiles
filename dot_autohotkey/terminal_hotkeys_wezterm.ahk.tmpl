#Requires AutoHotkey v2.0+
#SingleInstance
TraySetIcon "icons/terminal_white.ico", 1, true

; Returns a pwsh -c snippet that emits OSC 1337 SetUserVar for SSH_HOST before running cmd
Wezterm_run_with_SSH_HOST(host, cmd) {
	osc := "[Console]::Write([char]27+']1337;SetUserVar=SSH_HOST='+[Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes('" . host . "'))+[char]7)"
	return "wezterm-gui.exe -e pwsh.exe -c " . osc . ";" . cmd
}

^<!t::
{
	Run "wezterm-gui.exe", EnvGet("USERPROFILE"), , &PID
	WinWait 'ahk_pid ' PID
	Sleep 200
	WinActivate 'ahk_pid ' PID
}

^<!w::
{
	Run "wezterm-gui.exe -e wsl ~ tmux new -A -s default", , , &PID
	WinWait 'ahk_pid ' PID
	Sleep 200
	WinActivate 'ahk_pid ' PID
}

